# Copy to .env to override the local dev defaults below. Optional — the stack
# runs as-is with no .env present (these same defaults are baked into compose.yaml).

# Postgres credentials (shared by both databases)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Host ports — change if something already listens on 5432/5433 locally
BOOKING_DB_PORT=5432
INVENTORY_DB_PORT=5433
